# ============================================
# ShopeePay Payment Check System — .env config
# ============================================

# API Key dari shopee.putrahosting.com
SHOPEEPAY_API_KEY=shopee-secret-key-2026

# Base URL ShopeePay API proxy
SHOPEEPAY_BASE_URL=https://shopee.putrahosting.com

# QRIS String Statis dari merchant ShopeePay kamu
SHOPEEPAY_QRIS_STRING=00020101021126610016ID.CO.SHOPEE.WWW01189360091800230950980208230950980303UMI51440014ID.CO.QRIS.WWW0215ID10265233904290303UMI5204581753033605802ID5910Toko Putra6005BOGOR61051662062070703A0163044C0B

# Nama toko merchant
STORE_NAME=Toko Saya

# Admin dashboard password (hash SHA256 direkomendasikan)
ADMIN_PASSWORD=admin123

# Secret key untuk signing internal API calls
ADMIN_SECRET=change-this-to-random-secret

# Timeout payment dalam milidetik (default: 5 menit)
PAYMENT_TIMEOUT_MS=300000

# Random fee unik (min–max) untuk membedakan transaksi
FEE_MIN=1
FEE_MAX=97

# Port server
PORT=3000

# Environment: development | production
NODE_ENV=development
